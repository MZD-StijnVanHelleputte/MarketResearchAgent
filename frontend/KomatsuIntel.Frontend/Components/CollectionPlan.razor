@* Live collection plan: Collection Plan → Domain → Leaf → tool calls, with
   gray/green/red status counts rolling up at every level. Replaces the flat
   sources panel during collection; reused (completed) at Gate 2. *@

<MudPaper Elevation="1" Class="pa-3">
    <MudStack Spacing="2">

        @* Gate accept bar — pinned at the top so the user needn't scroll. *@
        @if (Mode == "gate1")
        {
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.CheckCircle"
                           OnClick="@(() => OnApprove.InvokeAsync())">
                    Approve plan
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                           StartIcon="@Icons.Material.Filled.Edit"
                           OnClick="@(() => OnRequestChanges.InvokeAsync())">
                    Request changes
                </MudButton>
            </MudStack>
            <MudDivider />
        }
        else if (Mode == "gate2")
        {
            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.CheckCircle"
                           OnClick="@(() => OnApprove.InvokeAsync())">
                    Approve &amp; Synthesize
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                           StartIcon="@Icons.Material.Filled.Replay"
                           OnClick="@(() => OnRedirect.InvokeAsync())">
                    Re-collect
                </MudButton>
            </MudStack>
            <MudDivider />
        }

        @* Top layer — the whole collection plan. *@
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="width:100%;">
            <MudText Typo="Typo.subtitle2" Style="font-weight:700;">Collection Plan</MudText>
            @StatusCounts(Plan.Pending, Plan.Succeeded, Plan.Failed)
        </MudStack>

        @if (Plan.Domains.Count == 0)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary"
                     Style="display:block;text-align:center;padding:24px 0;">
                The collection plan will appear here once research planning completes.
            </MudText>
        }

        <MudExpansionPanels MultiExpansion="true" Elevation="0">
            @foreach (var domain in Plan.Domains)
            {
                <MudExpansionPanel Style="border:1px solid #E5E7EB;border-radius:8px;margin-bottom:8px;">
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="width:100%;">
                            <MudText Typo="Typo.body2" Style="font-weight:700;">@domain.Display</MudText>
                            @StatusCounts(domain.Pending, domain.Succeeded, domain.Failed)
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        <MudExpansionPanels MultiExpansion="true" Elevation="0">
                            @foreach (var leaf in domain.Leaves)
                            {
                                <MudExpansionPanel Style="background:#F8F9FC;border-radius:6px;margin-bottom:6px;">
                                    <TitleContent>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Style="width:100%;">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                                <MudText Typo="Typo.body2" Style="font-weight:600;">@leaf.Label</MudText>
                                                @if (!string.IsNullOrWhiteSpace(leaf.LeafType))
                                                {
                                                    <span class="cp-leaf-type">@leaf.LeafType.Replace('_', ' ')</span>
                                                }
                                            </MudStack>
                                            @StatusCounts(leaf.Pending, leaf.Succeeded, leaf.Failed)
                                        </MudStack>
                                    </TitleContent>
                                    <ChildContent>
                                        @foreach (var call in leaf.ToolCalls)
                                        {
                                            <div class="cp-toolcall">
                                                <span class="cp-dot @DotClass(call.Status)"></span>
                                                <div style="flex:1;min-width:0;">
                                                    <div class="cp-toolcall-name">@call.Display</div>
                                                    @if (call.Status == "succeeded")
                                                    {
                                                        <div style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;margin-top:2px;">
                                                            <span style="@DataTypeChipStyle(call.DataType)">@DataTypeLabel(call.DataType)</span>
                                                            @{ var cl = CountLabel(call); }
                                                            @if (cl.Length > 0)
                                                            {
                                                                <span style="font-size:0.7rem;font-weight:600;color:#6B7280;">@cl</span>
                                                            }
                                                        </div>
                                                    }
                                                    else if (call.Status == "failed" && !string.IsNullOrWhiteSpace(call.Reason))
                                                    {
                                                        <div class="cp-toolcall-reason">@call.Reason</div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </ChildContent>
                                </MudExpansionPanel>
                            }
                        </MudExpansionPanels>
                    </ChildContent>
                </MudExpansionPanel>
            }
        </MudExpansionPanels>

    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired] public CollectionPlanView Plan { get; set; } = default!;
    // "live" (no action bar) · "gate1" (approve / request changes) · "gate2" (approve / re-collect)
    [Parameter] public string Mode { get; set; } = "live";
    [Parameter] public EventCallback OnApprove { get; set; }
    [Parameter] public EventCallback OnRedirect { get; set; }
    [Parameter] public EventCallback OnRequestChanges { get; set; }

    // Compact gray/green/red count widget, reused at plan, domain and leaf level.
    // Styles are inline so progress numbers stay readable even if app.css is stale.
    private RenderFragment StatusCounts(int pending, int succeeded, int failed) =>@<span class="cp-counts"
        aria-label="Collection progress"
        style="display:inline-flex;align-items:center;gap:8px;flex-shrink:0;">
        <span class="cp-count cp-count-pending" title="To do" style="@PendingCountStyle">
            <span class="cp-dot cp-dot-pending" style="@PendingDotStyle"></span>@pending
        </span>
        <span class="cp-count cp-count-success" title="Successful tool calls" style="@SuccessCountStyle">
            <span class="cp-dot cp-dot-success" style="@SuccessDotStyle"></span>@succeeded
        </span>
        <span class="cp-count cp-count-failed" title="Failed tool calls" style="@FailedCountStyle">
            <span class="cp-dot cp-dot-failed" style="@FailedDotStyle"></span>@failed
        </span>
    </span>;

    private const string PendingCountStyle =
        "display:inline-flex;align-items:center;justify-content:center;gap:4px;" +
        "min-width:38px;height:24px;padding:0 8px;border-radius:999px;" +
        "border:1px solid #E5E7EB;background:#F3F4F6;color:#4B5563;" +
        "font-size:0.72rem;font-weight:800;line-height:1;";

    private const string SuccessCountStyle =
        "display:inline-flex;align-items:center;justify-content:center;gap:4px;" +
        "min-width:38px;height:24px;padding:0 8px;border-radius:999px;" +
        "border:1px solid #BBF7D0;background:#DCFCE7;color:#166534;" +
        "font-size:0.72rem;font-weight:800;line-height:1;";

    private const string FailedCountStyle =
        "display:inline-flex;align-items:center;justify-content:center;gap:4px;" +
        "min-width:38px;height:24px;padding:0 8px;border-radius:999px;" +
        "border:1px solid #FECACA;background:#FEE2E2;color:#991B1B;" +
        "font-size:0.72rem;font-weight:800;line-height:1;";

    private const string PendingDotStyle =
        "display:inline-block;width:9px;height:9px;border-radius:50%;flex-shrink:0;background:#9CA3AF;";

    private const string SuccessDotStyle =
        "display:inline-block;width:9px;height:9px;border-radius:50%;flex-shrink:0;background:#22C55E;";

    private const string FailedDotStyle =
        "display:inline-block;width:9px;height:9px;border-radius:50%;flex-shrink:0;background:#EF4444;";

    private static string DotClass(string status) => status switch
    {
        "succeeded" => "cp-dot-success",
        "failed"    => "cp-dot-failed",
        _           => "cp-dot-pending",
    };

    // ── Per-tool-call result feedback (type + count) — mirrors the labels used in
    //    the legacy Sources panel so the two read consistently. ──────────────────
    private static string DataTypeLabel(string? dt) => dt switch
    {
        "numeric_series" => "numeric series",
        "financials"     => "financials",
        "articles"       => "news",
        "web_results"    => "web results",
        "filings"        => "filings",
        "document"       => "document",
        _                => "data",
    };

    private static string CountLabel(CpToolCall c) => c.DataType switch
    {
        _ when c.Count <= 0 => "",
        "numeric_series" or "financials" => $"{c.Count} rows",
        "articles"    => $"{c.Count} articles",
        "web_results" => $"{c.Count} results",
        "filings"     => $"{c.Count} filings",
        _             => $"{c.Count}",
    };

    private const string ChipBase =
        "display:inline-flex;align-items:center;padding:1px 8px;border-radius:999px;" +
        "font-size:0.68rem;font-weight:700;line-height:1.4;border:1px solid;";

    private static string DataTypeChipStyle(string? dt) => ChipBase + (dt switch
    {
        "numeric_series" or "financials" => "background:#DCFCE7;color:#166534;border-color:#BBF7D0;",
        "articles"    => "background:#FEF3C7;color:#92400E;border-color:#FDE68A;",
        "web_results" => "background:#DBEAFE;color:#1E40AF;border-color:#BFDBFE;",
        "filings"     => "background:#EDE9FE;color:#5B21B6;border-color:#DDD6FE;",
        _             => "background:#F3F4F6;color:#374151;border-color:#E5E7EB;",
    });
}
