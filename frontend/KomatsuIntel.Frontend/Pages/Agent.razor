    {
        await Api.ApproveGateAsync(_runId!, 1, new { });
        _awaitingGate     = null;
        _consolidatedPlan = null;
        _agentTyping      = true;
        _loading          = true;
        _currentThought   = null;
        _statusMessage    = "Gate 1 approved — collecting data…";
