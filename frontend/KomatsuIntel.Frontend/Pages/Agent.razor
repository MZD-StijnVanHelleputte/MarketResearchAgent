    // ── Timeout confirmation handlers ─────────────────────────────────────

    private async Task OnTimeoutContinue()
    {
        _awaitingTimeoutConfirm = false;
        _agentTyping            = true;
        _loading                = true;
        _currentThought         = null;
        _statusMessage          = "Continuing research…";
        StateHasChanged();
        await Api.ContinueAfterTimeoutAsync(_runId!);
        await PollUntilComplete(_pollCts!.Token);
    }

    private async Task OnTimeoutStop()
    {
        _awaitingTimeoutConfirm = false;
        _agentTyping            = true;
        _loading                = true;
        _currentThought         = null;
        _statusMessage          = "Assembling partial report…";
        StateHasChanged();
        await Api.StopAfterTimeoutAsync(_runId!);
        await PollUntilComplete(_pollCts!.Token);
    }

