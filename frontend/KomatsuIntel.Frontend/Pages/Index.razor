@page "/"

<PageTitle>Daily Brief — Komatsu Market Intelligence</PageTitle>

<div class="newspaper-wrapper">

    @* ── Date bar ──────────────────────────────────────────────────── *@
    <div class="newspaper-datebar">
        <span class="datebar-text">
            @DateTime.Today.ToString("dddd, MMMM d, yyyy")
            <span class="datebar-sep">&bull;</span>
            Morning Edition
        </span>
        <div class="datebar-actions">
            <MudTooltip Text="Go to Agent to generate a new brief">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Primary"
                           Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.SmartToy"
                           Href="/agent">
                    Run New Brief
                </MudButton>
            </MudTooltip>
        </div>
    </div>

    <div class="news-hr-thick"></div>
    <div class="news-hr-thin"></div>

    @* ── Empty state ───────────────────────────────────────────────── *@
    <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;
                padding:80px 24px;gap:16px;text-align:center;">
        <MudIcon Icon="@Icons.Material.Outlined.Newspaper"
                 Style="font-size:3.5rem;color:#D1D5DB;" />
        <MudText Typo="Typo.h6" Style="color:#6B7280;font-weight:600;">
            No brief for today yet
        </MudText>
        <MudText Typo="Typo.body2" Style="color:#9CA3AF;max-width:400px;">
            The daily brief is generated by the intelligence agent.
            Run a query on the Agent page to produce today's brief.
        </MudText>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.SmartToy"
                   Href="/agent">
            Go to Agent
        </MudButton>
    </div>

</div>

